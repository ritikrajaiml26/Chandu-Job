{% extends "admin/base.html" %}
{% load static %}

{% block title %}{% if subtitle %}{{ subtitle }} | {% endif %}{{ title }} | Chandu Job Portal{% endblock %}

{% block extrastyle %}
{{ block.super }}
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<style>
/* ============================================================
   CHANDU JOB PORTAL вЂ” PREMIUM ADMIN v3.0
   Full-Width Spacious Dark Theme
============================================================ */
:root {
    --primary:        #7c3aed;
    --primary-light:  #a78bfa;
    --primary-glow:   rgba(124,58,237,0.30);
    --accent:         #06b6d4;
    --success:        #10b981;
    --warning:        #f59e0b;
    --danger:         #ef4444;

    --bg-root:    #060514;
    --bg-surface: #0d0b22;
    --bg-card:    #111029;
    --bg-glass:   rgba(255,255,255,0.04);

    --border:        rgba(139,92,246,0.14);
    --border-bright: rgba(139,92,246,0.45);

    --text-1: #f1f5f9;
    --text-2: #94a3b8;
    --text-3: #475569;

    --header-h: 62px;
}

/* в”Ђв”Ђ BASE в”Ђв”Ђ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
    font-family: 'Inter', system-ui, sans-serif !important;
    background: var(--bg-root) !important;
    background-image:
        radial-gradient(ellipse 70% 45% at 15% -5%,  rgba(124,58,237,0.14) 0%, transparent 65%),
        radial-gradient(ellipse 55% 40% at 85% 105%, rgba(6,182,212,0.07)  0%, transparent 65%) !important;
    background-attachment: fixed !important;
    color: var(--text-1) !important;
    min-height: 100vh !important;
}

/* в”Ђв”Ђ SCROLLBAR в”Ђв”Ђ */
::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: var(--bg-surface); }
::-webkit-scrollbar-thumb { background: rgba(124,58,237,0.45); border-radius: 4px; }
::-webkit-scrollbar-thumb:hover { background: var(--primary-light); }

/* в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
   HEADER
в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
#header {
    position: sticky !important;
    top: 0 !important;
    z-index: 9999 !important;
    height: var(--header-h) !important;
    background: rgba(10,8,28,0.97) !important;
    backdrop-filter: blur(20px) !important;
    -webkit-backdrop-filter: blur(20px) !important;
    border-bottom: 1px solid var(--border) !important;
    box-shadow: 0 2px 20px rgba(0,0,0,0.5) !important;
    padding: 0 36px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: space-between !important;
}

/* Branding */
#branding { display: flex; align-items: center; }
#branding h1 { line-height: 1 !important; padding: 0 !important; }
#branding h1 a {
    display: flex !important;
    align-items: center !important;
    gap: 13px !important;
    text-decoration: none !important;
    color: var(--text-1) !important;
}
.brand-logo {
    width: 40px; height: 40px;
    background: linear-gradient(135deg, #7c3aed 0%, #06b6d4 100%);
    border-radius: 11px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.05rem; color: #fff;
    box-shadow: 0 4px 16px rgba(124,58,237,0.45);
    flex-shrink: 0;
}
.brand-name {
    font-size: 1rem !important;
    font-weight: 800 !important;
    letter-spacing: -0.025em !important;
    color: #fff !important;
    display: block;
}
.brand-sub {
    font-size: 0.6rem !important;
    font-weight: 600 !important;
    color: var(--primary-light) !important;
    letter-spacing: 0.1em !important;
    text-transform: uppercase !important;
    display: block;
    margin-top: 2px;
}

/* User tools */
#user-tools {
    display: flex !important;
    align-items: center !important;
    gap: 6px !important;
    font-size: 0.8rem !important;
}
#user-tools a {
    color: var(--text-2) !important;
    padding: 7px 14px !important;
    border-radius: 8px !important;
    border: 1px solid transparent !important;
    text-decoration: none !important;
    font-weight: 500 !important;
    transition: all 0.2s !important;
    display: inline-flex !important;
    align-items: center !important;
    gap: 5px !important;
}
#user-tools a:hover {
    background: var(--bg-glass) !important;
    border-color: var(--border) !important;
    color: #fff !important;
}
#user-tools a.logout-link, #user-tools a:last-child {
    background: linear-gradient(135deg, #7c3aed, #a78bfa) !important;
    color: #fff !important;
    border-color: transparent !important;
    box-shadow: 0 3px 12px var(--primary-glow) !important;
}
#user-tools a:last-child:hover {
    transform: translateY(-1px) !important;
    box-shadow: 0 6px 18px var(--primary-glow) !important;
}

/* в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
   BREADCRUMBS
в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.breadcrumbs {
    background: rgba(10,8,28,0.8) !important;
    border-bottom: 1px solid var(--border) !important;
    padding: 11px 36px !important;
    font-size: 0.78rem !important;
    color: var(--text-3) !important;
    font-weight: 500 !important;
}
.breadcrumbs a { color: var(--primary-light) !important; text-decoration: none !important; font-weight: 600 !important; }
.breadcrumbs a:hover { color: #fff !important; }

/* в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
   KILL SIDEBAR вЂ” FULL WIDTH
в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
#nav-sidebar         { display: none !important; }
.toggle-nav-sidebar-icon { display: none !important; }

/* Main layout full width */
.main, #main {
    display: block !important;
    width: 100% !important;
}

/* в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
   CONTENT WRAPPER
в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
#content {
    padding: 36px 44px !important;
    background: transparent !important;
    width: 100% !important;
    max-width: 100% !important;
    min-width: 0 !important;
}

#content-main, #content > div { width: 100% !important; float: none !important; }

#content h1 {
    font-size: 1.7rem !important;
    font-weight: 800 !important;
    letter-spacing: -0.03em !important;
    color: var(--text-1) !important;
    margin-bottom: 28px !important;
}

/* в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
   MODULE CARDS
в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.module {
    background: var(--bg-card) !important;
    border: 1px solid var(--border) !important;
    border-radius: 18px !important;
    overflow: hidden !important;
    box-shadow: 0 8px 32px rgba(0,0,0,0.35) !important;
    margin-bottom: 28px !important;
    transition: border-color 0.2s, box-shadow 0.2s !important;
}
.module:hover {
    border-color: var(--border-bright) !important;
    box-shadow: 0 16px 48px rgba(0,0,0,0.45) !important;
}
.module h2, .module caption {
    background: rgba(124,58,237,0.08) !important;
    color: var(--text-1) !important;
    border-bottom: 1px solid var(--border) !important;
    padding: 16px 24px !important;
    font-weight: 700 !important;
    font-size: 0.88rem !important;
    letter-spacing: -0.01em !important;
}

/* в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
   TABLES
в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
table { border-collapse: collapse !important; width: 100% !important; }
thead th {
    background: rgba(5,4,17,0.7) !important;
    color: var(--text-3) !important;
    font-weight: 700 !important;
    font-size: 0.67rem !important;
    text-transform: uppercase !important;
    letter-spacing: 0.08em !important;
    padding: 13px 18px !important;
    border-bottom: 1px solid var(--border) !important;
}
td {
    padding: 13px 18px !important;
    border-bottom: 1px solid rgba(139,92,246,0.07) !important;
    font-size: 0.855rem !important;
    color: var(--text-2) !important;
}
tr.row1 { background: rgba(13,11,34,0.5) !important; }
tr.row2 { background: rgba(6,5,20,0.4) !important; }
tr:hover td { background: rgba(124,58,237,0.07) !important; }
th a, td a { color: var(--primary-light) !important; text-decoration: none !important; font-weight: 600 !important; }
th a:hover, td a:hover { color: #fff !important; }

/* в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
   FORMS вЂ” FULL WIDTH STACKED
в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */

/* Fieldsets get card look */
fieldset {
    border: none !important;
    padding: 0 !important;
    margin: 0 !important;
}

/* Module card inside form */
.module fieldset {
    width: 100% !important;
}

/* Each form row = label on top, full-width input below */
.form-row {
    display: block !important;
    padding: 22px 36px !important;
    border-bottom: 1px solid rgba(139,92,246,0.07) !important;
    background: transparent !important;
}

/* Label styling */
.form-row > label,
.form-row label:first-child {
    display: block !important;
    font-weight: 700 !important;
    font-size: 0.82rem !important;
    color: var(--text-2) !important;
    letter-spacing: 0.02em !important;
    text-transform: uppercase !important;
    margin-bottom: 10px !important;
    float: none !important;
    width: auto !important;
    padding-top: 0 !important;
}

/* div.field-box inside form-row */
.form-row .field-box {
    float: none !important;
    width: 100% !important;
    clear: both !important;
}

/* ALL inputs, selects, textareas вЂ” full width */
.form-row input[type=text],
.form-row input[type=password],
.form-row input[type=email],
.form-row input[type=url],
.form-row input[type=number],
.form-row input[type=date],
.form-row input[type=file],
.form-row select,
.form-row textarea {
    background: rgba(6,5,20,0.85) !important;
    border: 1px solid rgba(139,92,246,0.22) !important;
    border-radius: 12px !important;
    padding: 13px 18px !important;
    font-size: 0.95rem !important;
    color: var(--text-1) !important;
    font-family: 'Inter', sans-serif !important;
    width: 100% !important;
    max-width: 100% !important;
    box-sizing: border-box !important;
    transition: border-color 0.2s, box-shadow 0.2s, background 0.2s !important;
    outline: none !important;
    line-height: 1.7 !important;
    display: block !important;
    float: none !important;
}

/* Textarea specific */
.form-row textarea {
    resize: vertical !important;
    min-height: 120px !important;
}

/* Focus state */
.form-row input:focus,
.form-row select:focus,
.form-row textarea:focus {
    border-color: var(--primary-light) !important;
    box-shadow: 0 0 0 4px rgba(139,92,246,0.15) !important;
    background: rgba(10,8,30,0.95) !important;
}

/* Select arrow color */
.form-row select {
    appearance: auto !important;
    cursor: pointer !important;
}

/* Help text below input */
.help, .help-block {
    font-size: 0.78rem !important;
    color: var(--text-3) !important;
    margin-top: 8px !important;
    display: block !important;
    line-height: 1.5 !important;
}

/* Required asterisk */
.required {
    color: #a78bfa !important;
    font-size: 0.8rem !important;
}

/* Error messages in forms */
.errorlist {
    color: #f87171 !important;
    font-size: 0.82rem !important;
    list-style: none !important;
    padding: 0 !important;
    margin: 8px 0 0 !important;
    display: block !important;
}
.errorlist li {
    background: rgba(239,68,68,0.08) !important;
    border: 1px solid rgba(239,68,68,0.2) !important;
    border-radius: 8px !important;
    padding: 8px 12px !important;
    margin-bottom: 4px !important;
}

/* в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
   BUTTONS
в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.button, input[type=submit], input[type=button], a.button {
    border-radius: 9px !important; font-weight: 600 !important; padding: 9px 22px !important;
    font-size: 0.83rem !important; border: 1px solid transparent !important;
    cursor: pointer !important; font-family: 'Inter', sans-serif !important;
    display: inline-flex !important; align-items: center !important; gap: 7px !important;
    text-decoration: none !important; transition: all 0.2s !important; letter-spacing: -0.01em !important;
}
.button.default, input[type=submit] {
    background: linear-gradient(135deg, #7c3aed, #a78bfa) !important;
    color: #fff !important; box-shadow: 0 4px 14px var(--primary-glow) !important;
}
.button.default:hover, input[type=submit]:hover {
    transform: translateY(-2px) !important; box-shadow: 0 8px 22px var(--primary-glow) !important;
}
.deletelink, .submit-row a.deletelink {
    background: rgba(239,68,68,0.1) !important; color: #ef4444 !important;
    border-color: rgba(239,68,68,0.22) !important;
}
.deletelink:hover { background: rgba(239,68,68,0.2) !important; color: #fca5a5 !important; }
.submit-row {
    background: rgba(6,5,20,0.8) !important; border-top: 1px solid var(--border) !important;
    border-radius: 0 0 18px 18px !important; padding: 18px 28px !important;
    display: flex !important; gap: 12px !important; align-items: center !important;
}

/* в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
   OBJECT TOOLS & ACTIONS
в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.object-tools { margin-bottom: 20px !important; display: flex !important; gap: 10px !important; }
.object-tools a {
    background: linear-gradient(135deg, #7c3aed, #a78bfa) !important;
    color: #fff !important; border-radius: 9px !important; font-weight: 600 !important;
    padding: 9px 18px !important; font-size: 0.82rem !important;
    box-shadow: 0 4px 12px var(--primary-glow) !important;
    text-decoration: none !important; transition: all 0.2s !important;
    display: inline-flex !important; align-items: center !important; gap: 6px !important;
}
.object-tools a:hover { transform: translateY(-2px) !important; box-shadow: 0 8px 22px var(--primary-glow) !important; }
.actions {
    background: var(--bg-card) !important; border: 1px solid var(--border) !important;
    border-radius: 10px !important; padding: 12px 18px !important; margin-bottom: 20px !important;
    display: flex !important; align-items: center !important; gap: 12px !important;
}
.actions select {
    background: rgba(4,3,16,0.8) !important; border: 1px solid var(--border) !important;
    border-radius: 8px !important; padding: 7px 12px !important;
    color: var(--text-1) !important; font-size: 0.82rem !important; font-family: 'Inter', sans-serif !important;
}

/* в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
   FILTER SIDEBAR
в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
#changelist-filter {
    background: var(--bg-card) !important; border: 1px solid var(--border) !important;
    border-radius: 14px !important; padding: 20px !important; box-shadow: 0 8px 28px rgba(0,0,0,0.3) !important;
}
#changelist-filter h2 {
    font-weight: 800 !important; font-size: 0.68rem !important; color: var(--text-3) !important;
    text-transform: uppercase !important; letter-spacing: 0.12em !important;
    border-bottom: 1px solid var(--border) !important; padding-bottom: 10px !important; margin-bottom: 14px !important;
}
#changelist-filter h3 { font-size: 0.76rem !important; color: var(--text-2) !important; font-weight: 700 !important; margin-top: 16px !important; margin-bottom: 6px !important; }
#changelist-filter ul { padding-left: 0 !important; list-style: none !important; }
#changelist-filter li a {
    color: var(--text-3) !important; font-size: 0.82rem !important; display: block !important;
    padding: 5px 8px !important; border-radius: 6px !important; text-decoration: none !important; transition: all 0.15s !important;
}
#changelist-filter li.selected a, #changelist-filter li a:hover {
    color: var(--primary-light) !important; background: rgba(124,58,237,0.1) !important; font-weight: 600 !important;
}

/* в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
   PAGINATION
в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.paginator { color: var(--text-3) !important; font-size: 0.83rem !important; padding: 16px 0 !important; display: flex !important; align-items: center !important; gap: 5px !important; }
.paginator a {
    background: var(--bg-card) !important; border: 1px solid var(--border) !important; color: var(--text-2) !important;
    padding: 5px 12px !important; border-radius: 7px !important; text-decoration: none !important; font-weight: 500 !important; transition: all 0.2s !important;
}
.paginator a:hover { border-color: var(--primary-light) !important; color: var(--primary-light) !important; background: rgba(124,58,237,0.1) !important; }
.paginator .this-page { background: var(--primary) !important; color: #fff !important; padding: 5px 12px !important; border-radius: 7px !important; font-weight: 700 !important; }

/* в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
   MESSAGES
в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.messagelist { margin: 0 0 24px !important; padding: 0 !important; list-style: none !important; }
.messagelist li {
    padding: 12px 18px !important; border-radius: 10px !important; font-weight: 600 !important;
    font-size: 0.84rem !important; margin-bottom: 8px !important; border: 1px solid !important;
    display: flex !important; align-items: center !important; gap: 10px !important;
}
.messagelist li.success { background: rgba(16,185,129,0.09) !important; color: #34d399 !important; border-color: rgba(16,185,129,0.22) !important; }
.messagelist li.error   { background: rgba(239,68,68,0.09) !important;  color: #f87171 !important; border-color: rgba(239,68,68,0.22) !important; }
.messagelist li.warning { background: rgba(245,158,11,0.09) !important;  color: #fbbf24 !important; border-color: rgba(245,158,11,0.22) !important; }

/* в”Ђв”/* в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
   LOGIN PAGE
 в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.login #header { display: none !important; }
.login { background: var(--bg-root) !important; }
.login #container {
    display: flex !important;
    flex-direction: column !important;
    align-items: center !important;
    justify-content: center !important;
    min-height: 100vh !important;
    width: 100% !important;
    max-width: 100% !important;
    margin: 0 !important;
    border: none !important;
    background: transparent !important;
    box-shadow: none !important;
}
.login #main {
    background: transparent !important;
    width: 100% !important;
    display: flex !important;
    justify-content: center !important;
    align-items: center !important;
    flex: 1 0 auto !important;
}
.login #content {
    background: var(--bg-card) !important;
    border: 1px solid var(--border) !important;
    border-radius: 22px !important;
    box-shadow: 0 24px 64px rgba(0,0,0,0.6) !important;
    width: 100% !important;
    max-width: 420px !important;
    padding: 44px !important;
    box-sizing: border-box !important;
}
.login .form-row { grid-template-columns: 1fr !important; padding: 12px 0 !important; border: none !important; background: transparent !important; }
.login .form-row label { display: block !important; margin-bottom: 7px !important; padding-top: 0 !important; }
.login .form-row input { max-width: 100% !important; }
.login .submit-row { padding: 20px 0 0 !important; border: none !important; background: transparent !important; border-radius: 0 !important; }
.login input[type=submit] { width: 100% !important; padding: 12px !important; font-size: 0.92rem !important; }
.login #footer { display: none !important; }{ background-color: #ffffff !important; color: #1e1b4b !important; }
.errornote { background: rgba(239,68,68,0.09) !important; border: 1px solid rgba(239,68,68,0.22) !important; color: #f87171 !important; border-radius: 10px !important; padding: 12px 16px !important; }
.errorlist { color: #f87171 !important; font-size: 0.8rem !important; list-style: none !important; padding-left: 0 !important; margin-top: 4px !important; }
.sorted { color: var(--primary-light) !important; }

/* в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
   LOGIN PAGE
в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.login #header { display: none !important; }
.login { background: var(--bg-root) !important; }
.login #container { display: flex !important; align-items: center !important; justify-content: center !important; min-height: 100vh !important; }
.login #content {
    background: var(--bg-card) !important; border: 1px solid var(--border) !important;
    border-radius: 22px !important; box-shadow: 0 24px 64px rgba(0,0,0,0.6) !important;
    width: 100% !important; max-width: 420px !important; padding: 44px !important;
}
.login .form-row { grid-template-columns: 1fr !important; padding: 12px 0 !important; border: none !important; background: transparent !important; }
.login .form-row label { display: block !important; margin-bottom: 7px !important; padding-top: 0 !important; }
.login .form-row input { max-width: 100% !important; }
.login .submit-row { padding: 20px 0 0 !important; border: none !important; background: transparent !important; border-radius: 0 !important; }
.login input[type=submit] { width: 100% !important; padding: 12px !important; font-size: 0.92rem !important; }

/* в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
   INLINE GROUPS
в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
.inline-group { background: var(--bg-card) !important; border: 1px solid var(--border) !important; border-radius: 14px !important; overflow: hidden !important; margin-top: 24px !important; }
.inline-group h2 { background: rgba(124,58,237,0.07) !important; color: var(--text-1) !important; padding: 14px 22px !important; font-size: 0.88rem !important; font-weight: 700 !important; border-bottom: 1px solid var(--border) !important; }

/* в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
   FOOTER
в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
#footer { text-align: center !important; padding: 18px !important; color: var(--text-3) !important; font-size: 0.76rem !important; border-top: 1px solid var(--border) !important; background: rgba(10,8,28,0.6) !important; }

/* в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
   ANIMATION
в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
@keyframes fadeSlide { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
#content { animation: fadeSlide 0.3s ease !important; }
</style>
{% endblock %}

