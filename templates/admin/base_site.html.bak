    <a href="{% url 'admin:index' %}">
        <span class="brand-logo"><i class="fa-solid fa-gauge-high"></i></span>
        <span>
            <span class="brand-name">Chandu Job Portal</span>
            <span class="brand-sub">Admin Control Panel</span>
        </span>
    </a>
</h1>
